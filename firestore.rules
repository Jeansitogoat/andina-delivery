rules_version = '2';
// Andina Express — reglas listas para producción (Motor Real-Time + paneles).
// Reemplaza TODO el contenido de la consola Firebase con este archivo.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return request.auth.token.get('rol', '');
    }

    function tokenLocalId() {
      return request.auth.token.get('localId', '');
    }

    // --- users: yo mismo; central/maestro leen riders (onSnapshot en panel Central) ---
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || getRole() in ['central', 'maestro']
      );
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- pedidos ---
    match /pedidos/{pedidoId} {
      allow read: if isSignedIn() && (
        resource.data.clienteId == request.auth.uid
        || resource.data.riderId == request.auth.uid
        || getRole() in ['central', 'maestro']
        || (
          getRole() == 'local'
          && resource.data.localId == tokenLocalId()
        )
      );

      allow create: if isSignedIn() && request.resource.data.clienteId == request.auth.uid;

      allow update: if isSignedIn() && (
        getRole() in ['central', 'maestro']
        || (
          resource.data.riderId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'updatedAt', 'ubicacionRider'])
        )
        || (
          resource.data.localId == tokenLocalId()
          && getRole() == 'local'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'estado', 'updatedAt', 'motivoCancelacion', 'preparacion',
            'paymentConfirmed', 'comprobanteBase64', 'comprobanteFileName', 'comprobanteMimeType'
          ])
        )
      );

      allow delete: if isSignedIn() && getRole() in ['central', 'maestro'];
    }

    // --- comisiones: solo lectura; escritura solo Admin SDK ---
    match /comisiones/{comisionId} {
      allow read: if isSignedIn() && (
        resource.data.riderId == request.auth.uid
        || (
          getRole() == 'local'
          && resource.data.localId == tokenLocalId()
        )
        || getRole() in ['central', 'maestro']
      );
      allow create, update, delete: if false;
    }

    // --- locales + subcolecciones (ej. productos): público lee; maestro o el dueño del local escribe ---
    match /locales/{localId}/{document=**} {
      allow read: if true;
      allow write: if isSignedIn() && (
        getRole() == 'maestro'
        || (getRole() == 'local' && tokenLocalId() == localId)
      );
    }

    match /banners/{document=**} {
      allow read: if true;
      allow write: if isSignedIn() && getRole() == 'maestro';
    }

    match /config/{document=**} {
      allow read: if true;
      allow write: if isSignedIn() && getRole() == 'maestro';
    }

    match /solicitudes/{solicitudId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn() && getRole() == 'maestro';
    }

    // --- mandados (express): documentos planos; seguimiento cliente con onSnapshot ---
    match /mandados/{mandadoId} {
      allow read: if isSignedIn() && (
        resource.data.clienteId == request.auth.uid
        || resource.data.riderId == request.auth.uid
        || getRole() in ['central', 'maestro']
      );
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
