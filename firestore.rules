rules_version = '2';
// Andina Express – Reglas v2 con Custom Claims (Fase 3).
// El rol se lee desde request.auth.token.rol (JWT claim) en lugar de get(users/{uid}).
// Esto elimina las lecturas extra de Firestore que generaba la función getRole().
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: obtiene el rol del usuario desde el JWT custom claim.
    // Cero lecturas adicionales de Firestore — el claim viaja en el token.
    // Fallback vacío para usuarios legacy que aún no tienen el claim fijado.
    function getRole() {
      return request.auth.token.get('rol', '');
    }

    // 1. Usuarios: cada uno solo puede leer/escribir su propio documento
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 2. Pedidos
    match /pedidos/{pedidoId} {
      allow read: if request.auth != null && (
        resource.data.clienteId == request.auth.uid
        || resource.data.riderId == request.auth.uid
        || getRole() in ['central', 'maestro']
      );
      allow create: if request.auth != null && request.resource.data.clienteId == request.auth.uid;
      allow update: if request.auth != null && (
        getRole() in ['central', 'maestro']
        || (resource.data.riderId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'updatedAt', 'ubicacionRider']))
      );
      allow delete: if request.auth != null && getRole() in ['central', 'maestro'];
    }

    // 3. Comisiones: lectura solo si el rider es el dueño; escritura denegada (solo Admin SDK)
    match /comisiones/{comisionId} {
      allow read: if request.auth != null && resource.data.riderId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // 4. Locales, Banners y Config: lectura pública; escritura solo maestro
    match /locales/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && getRole() == 'maestro';
    }
    match /banners/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && getRole() == 'maestro';
    }
    match /config/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && getRole() == 'maestro';
    }

    // 5. Solicitudes: creación pública (nuevos locales); lectura/escritura solo maestro
    match /solicitudes/{solicitudId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && getRole() == 'maestro';
    }

    // Seguridad global: todo lo no especificado denegado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
