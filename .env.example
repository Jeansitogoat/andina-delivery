# ─────────────────────────────────────────────────────────────────────────────
# Andina Delivery - Piñas · Variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copia este archivo:  cp .env.example .env.local
# 2. Rellena los valores con tus credenciales de Firebase.
# 3. public/firebase-messaging-sw.js se genera automáticamente en npm run build/dev.
#    Ese archivo está en .gitignore; no versionarlo (contiene credenciales).
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Web (frontend) · Requeridas ──
# Firebase Console > Configuración del proyecto > General > Tus apps
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Opcional · Firebase Analytics
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── FCM Push Notifications · Requerida para notificaciones ──
# Firebase Console > Cloud Messaging > Web Push > Par de claves
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ── Firebase Admin (backend) · Requerida ──
# JSON completo de la cuenta de servicio (una línea, escapado o minificado)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Contacto ──
# WhatsApp para /socios. Fallback interno: 593983511866
# NEXT_PUBLIC_WHATSAPP_SOCIOS=

# ── Cron externo (opcional) ──
# Token Bearer para /api/cron/notificar-comisiones
# CRON_SECRET=
