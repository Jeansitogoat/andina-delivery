# ─────────────────────────────────────────────────────────────────────────────
# Andina Express · Variables de entorno
# Copia este archivo a .env.local y ajusta los valores.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase Web (frontend) · claves públicas (el Service Worker se genera desde estas en npm run build/dev)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=       # opcional
# NEXT_PUBLIC_FIREBASE_VAPID_KEY=            # Necesario para notificaciones push: Firebase Console > Cloud Messaging > Web Push

# Firebase Admin (backend API) · solo JSON en variable (sin archivo físico)
# FIREBASE_SERVICE_ACCOUNT_JSON=             # Contenido completo del JSON de la cuenta de servicio (una línea o escapado)

# Notificaciones y contacto
# NEXT_PUBLIC_WHATSAPP_SOCIOS=593992250333   # número de WhatsApp para la página de socios

# Cron (comisiones)
# CRON_SECRET=                               # token que usará el cron externo para /api/cron/notificar-comisiones
